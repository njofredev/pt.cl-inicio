---
interface Props {
  name: string;
  description: string;
  url: string;
  status: 'online' | 'maintenance' | 'offline';
  category: string;
  metric?: string;
  metricLabel?: string;
}

const { name, description, url, status, category, metric, metricLabel } = Astro.props;

// Select status label in Spanish
const statusText = {
  online: 'Operativo',
  maintenance: 'Mantenimiento',
  offline: 'Inactivo'
}[status];
---

<a href={url} target="_blank" rel="noopener noreferrer" class="app-card glass-panel glow-card" data-category={category.toLowerCase()} data-name={name.toLowerCase()} data-desc={description.toLowerCase()}>
  <div class="card-header">
    <div class="icon-container">
      <slot name="icon">
        <!-- Default Fallback SVG Icon if none passed -->
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
      </slot>
    </div>
    <span class={`status-badge ${status}`}>{statusText}</span>
  </div>

  <div class="card-body">
    <span class="category-tag">{category}</span>
    <h3 class="app-title">{name}</h3>
    <p class="app-description">{description}</p>
  </div>

  {metric && (
    <div class="card-footer">
      <div class="metric-container">
        <span class="metric-value">{metric}</span>
        <span class="metric-label">{metricLabel}</span>
      </div>
      <div class="arrow-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </div>
    </div>
  )}
</a>

<style>
  .app-card {
    display: flex;
    flex-direction: column;
    padding: 20px;
    text-decoration: none;
    color: var(--color-text-primary);
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .app-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, transparent, rgba(0, 180, 240, 0.4), transparent);
    transform: translateX(-100%);
    transition: transform 0.6s ease;
  }

  .app-card:hover::before {
    transform: translateX(100%);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .icon-container {
    color: var(--color-primary);
    background: rgba(0, 180, 240, 0.08);
    padding: 10px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(0, 180, 240, 0.15);
    transition: all 0.3s ease;
  }

  .app-card:hover .icon-container {
    color: var(--color-text-primary);
    background: var(--color-primary);
    box-shadow: 0 0 15px rgba(0, 180, 240, 0.4);
    border-color: var(--color-primary);
    transform: scale(1.05);
  }

  .card-body {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .category-tag {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    font-weight: 600;
    margin-bottom: 6px;
  }

  .app-title {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  .app-card:hover .app-title {
    color: var(--color-primary);
  }

  .app-description {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.45;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .metric-container {
    display: flex;
    flex-direction: column;
  }

  .metric-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-success);
  }

  .metric-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .arrow-icon {
    color: var(--color-text-muted);
    transition: all 0.3s ease;
    transform: translateX(0);
  }

  .app-card:hover .arrow-icon {
    color: var(--color-primary);
    transform: translateX(4px);
  }
</style>
