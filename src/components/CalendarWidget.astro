---
const today = new Date();
const monthNames = [
  "Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio",
  "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"
];
const dayNames = ["Lun", "Mar", "Mié", "Jue", "Vie", "Sáb", "Dom"];

const currentMonthName = monthNames[today.getMonth()];
const currentYear = today.getFullYear();
const currentDay = today.getDate();

// Generate calendar cells (e.g. for June 2026)
// June 1st 2026 is a Monday (1)
// Let's create a realistic mock grid for the current month
const totalDays = 30; // e.g. June has 30 days
const startOffset = 0; // Starts on Monday
const daysArray = [];

for (let i = 1; i <= totalDays; i++) {
  daysArray.push({
    dayNum: i,
    isToday: i === currentDay,
    hasEvent: [5, 12, 18, 26].includes(i),
    eventColor: i === 12 ? 'warning' : 'primary'
  });
}
---

<div class="calendar-widget glass-panel">
  <div class="calendar-header">
    <div class="calendar-title">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      <span>Turnos y Calendario</span>
    </div>
    <span class="month-year">{currentMonthName} {currentYear}</span>
  </div>

  <div class="calendar-body">
    <div class="days-header-grid">
      {dayNames.map(day => <span class="day-name">{day}</span>)}
    </div>
    <div class="days-cells-grid">
      {daysArray.map(item => (
        <span class={`day-cell ${item.isToday ? 'today' : ''} ${item.hasEvent ? 'has-event ' + item.eventColor : ''}`}>
          {item.dayNum}
        </span>
      ))}
    </div>
  </div>

  <div class="shift-alerts">
    <span class="alerts-title">Avisos & Turnos de Hoy</span>
    
    <div class="alert-item primary">
      <div class="alert-indicator"></div>
      <div class="alert-details">
        <span class="alert-time">08:00 - 20:00</span>
        <span class="alert-text">Dr. Alejandro Medina (Urgencias)</span>
      </div>
    </div>

    <div class="alert-item warning">
      <div class="alert-indicator"></div>
      <div class="alert-details">
        <span class="alert-time">22:00 - 23:30</span>
        <span class="alert-text">Mantenimiento planificado Ficha Clínica</span>
      </div>
    </div>
  </div>
</div>

<style>
  .calendar-widget {
    padding: 24px;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }

  .calendar-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .calendar-title svg {
    color: var(--color-primary);
  }

  .month-year {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    background: rgba(255, 255, 255, 0.04);
    padding: 4px 10px;
    border-radius: 8px;
  }

  .calendar-body {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 12px;
    padding: 16px;
    border: 1px solid rgba(255, 255, 255, 0.02);
    margin-bottom: 20px;
  }

  .days-header-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 8px;
    text-align: center;
    margin-bottom: 12px;
  }

  .day-name {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .days-cells-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 8px;
    text-align: center;
  }

  .day-cell {
    font-size: 0.82rem;
    font-weight: 500;
    padding: 6px 0;
    border-radius: 8px;
    color: var(--color-text-secondary);
    position: relative;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .day-cell:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-text-primary);
  }

  .day-cell.today {
    background: var(--color-primary);
    color: var(--bg-base);
    font-weight: 700;
    box-shadow: 0 0 10px rgba(0, 180, 240, 0.5);
  }

  .day-cell.has-event::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
  }

  .day-cell.has-event.primary::after {
    background: var(--color-primary);
    box-shadow: 0 0 4px var(--color-primary);
  }

  .day-cell.has-event.warning::after {
    background: var(--color-warning);
    box-shadow: 0 0 4px var(--color-warning);
  }

  .shift-alerts {
    margin-top: auto;
  }

  .alerts-title {
    font-size: 0.72rem;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 600;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 12px;
  }

  .alert-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 10px;
    border-left: 3px solid transparent;
    margin-bottom: 8px;
  }

  .alert-item.primary {
    border-left-color: var(--color-primary);
  }

  .alert-item.warning {
    border-left-color: var(--color-warning);
  }

  .alert-indicator {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .primary .alert-indicator {
    background: var(--color-primary);
    box-shadow: 0 0 6px var(--color-primary);
  }

  .warning .alert-indicator {
    background: var(--color-warning);
    box-shadow: 0 0 6px var(--color-warning);
  }

  .alert-details {
    display: flex;
    flex-direction: column;
  }

  .alert-time {
    font-size: 0.65rem;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .alert-text {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    font-weight: 500;
  }
</style>
