---
---
<div class="status-widget glass-panel">
  <div class="widget-header">
    <div class="widget-title">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>
      <span>Estado del Ecosistema</span>
    </div>
    <span class="pulse-indicator"></span>
  </div>

  <div class="stats-grid">
    <div class="stat-item">
      <span class="stat-label">Usuarios Activos</span>
      <div class="stat-value-container">
        <span class="stat-value text-gradient-cyan">184</span>
        <span class="stat-trend success">↑ 12%</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" style="width: 72%; background: var(--color-primary)"></div>
      </div>
    </div>

    <div class="stat-item">
      <span class="stat-label">Uptime General (30d)</span>
      <div class="stat-value-container">
        <span class="stat-value text-gradient-emerald">99.98%</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" style="width: 99.98%; background: var(--color-success)"></div>
      </div>
    </div>

    <div class="stat-item">
      <span class="stat-label">Carga Base de Datos</span>
      <div class="stat-value-container">
        <span class="stat-value" style="color: var(--color-warning);">24%</span>
        <span class="stat-status">Estable</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" style="width: 24%; background: var(--color-warning)"></div>
      </div>
    </div>

    <div class="stat-item">
      <span class="stat-label">Latencia Promedio</span>
      <div class="stat-value-container">
        <span class="stat-value">12 ms</span>
        <span class="stat-status success">Óptimo</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" style="width: 15%; background: var(--color-primary)"></div>
      </div>
    </div>
  </div>

  <div class="node-status-list">
    <div class="node-item">
      <span class="node-name">Servidor Web Principal</span>
      <span class="status-dot online">Online</span>
    </div>
    <div class="node-item">
      <span class="node-name">API Gateway</span>
      <span class="status-dot online">Online</span>
    </div>
    <div class="node-item">
      <span class="node-name">Base de Datos PostgreSQL</span>
      <span class="status-dot online">Online</span>
    </div>
    <div class="node-item">
      <span class="node-name">Servicio de Notificaciones</span>
      <span class="status-dot maintenance">Mantenimiento</span>
    </div>
  </div>
</div>

<style>
  .status-widget {
    padding: 24px;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .widget-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .widget-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
  }

  .widget-title svg {
    color: var(--color-primary);
  }

  .pulse-indicator {
    width: 8px;
    height: 8px;
    background: var(--color-success);
    border-radius: 50%;
    position: relative;
    box-shadow: 0 0 10px var(--color-success);
  }

  .pulse-indicator::after {
    content: '';
    position: absolute;
    top: -4px;
    left: -4px;
    right: -4px;
    bottom: -4px;
    border: 1px solid var(--color-success);
    border-radius: 50%;
    animation: radar-pulse 2s infinite ease-out;
  }

  @keyframes radar-pulse {
    0% {
      transform: scale(0.8);
      opacity: 1;
    }
    100% {
      transform: scale(2.2);
      opacity: 0;
    }
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 24px;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
  }

  .stat-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
  }

  .stat-value-container {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 8px;
  }

  .stat-value {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .stat-trend {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 1px 6px;
    border-radius: 4px;
  }

  .stat-trend.success {
    background: rgba(43, 218, 116, 0.1);
    color: var(--color-success);
  }

  .stat-status {
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }

  .stat-status.success {
    color: var(--color-success);
  }

  .progress-bar {
    width: 100%;
    height: 4px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    border-radius: 2px;
  }

  .node-status-list {
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .node-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.82rem;
  }

  .node-name {
    color: var(--color-text-secondary);
  }

  .status-dot {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .status-dot::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    display: inline-block;
  }

  .status-dot.online {
    color: var(--color-success);
  }
  .status-dot.online::before {
    background: var(--color-success);
    box-shadow: 0 0 6px var(--color-success);
  }

  .status-dot.maintenance {
    color: var(--color-warning);
  }
  .status-dot.maintenance::before {
    background: var(--color-warning);
    box-shadow: 0 0 6px var(--color-warning);
  }
</style>
